@page
@model NegocioWeb.Pages.ProductosModel
@{
    ViewData["Title"] = "Gestión de Productos";
}

<div class="row mb-4 align-items-center">
    <div class="col">
        <h2 class="fw-bold text-dark mb-1"><i class="bi bi-box-seam me-2 text-primary"></i>Productos</h2>
        <p class="text-muted mb-0">Catálogo de productos, control de stock y márgenes de ganancia.</p>
    </div>
    <div class="col-auto">
        <button type="button" class="btn btn-custom-primary" data-bs-toggle="modal" data-bs-target="#productoModal">
            <i class="bi bi-plus-circle me-2"></i> Nuevo Producto
        </button>
    </div>
</div>

<!-- Search and Filters -->
<div class="row mb-4 g-3">
    <div class="col-md-5">
        <div class="card card-custom p-2">
            <div class="input-group">
                <span class="input-group-text bg-transparent border-0"><i class="bi bi-search text-muted"></i></span>
                <input type="text" class="form-control border-0 ps-0" placeholder="Buscar por nombre, código..." />
            </div>
        </div>
    </div>
    <div class="col-md-3 col-sm-6">
        <div class="card card-custom p-2">
            <select class="form-select border-0 bg-transparent">
                <option value="">Todas las Categorías</option>
                <option value="1">Útiles escolares</option>
                <option value="2">Cuadernos y Repuestos</option>
                <option value="3">Tecnología básica</option>
                <option value="4">Limpieza</option>
            </select>
        </div>
    </div>
    <div class="col-md-2 col-sm-6">
        <div class="card card-custom p-2">
            <select class="form-select border-0 bg-transparent">
                <option value="">Todas las Marcas</option>
                <option value="1">Rivadavia</option>
                <option value="2">Bic</option>
                <option value="3">Pizzini</option>
            </select>
        </div>
    </div>
    <div class="col-md-2">
        <div class="card card-custom p-2">
            <select class="form-select border-0 bg-transparent">
                <option value="todos">Todos los Stocks</option>
                <option value="bajo">Stock Bajo</option>
                <option value="ok">Stock OK</option>
            </select>
        </div>
    </div>
</div>

<!-- Products Table -->
<div class="card card-custom p-4">
    <div class="table-responsive">
        <table class="table table-custom align-middle">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Nombre</th>
                    <th>Marca</th>
                    <th>Categoría</th>
                    <th>Stock Actual</th>
                    <th>Stock Mín.</th>
                    <th>% Ganancia</th>
                    <th>Precio Compra (Últ.)</th>
                    <th>Precio Venta</th>
                    <th>Estado</th>
                    <th class="text-end">Acciones</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td>1</td>
                    <td class="fw-bold">Cuaderno A4 84 Hojas Rayado</td>
                    <td>Rivadavia</td>
                    <td>Cuadernos</td>
                    <td>
                        <span class="badge badge-custom badge-custom-success">30 u</span>
                    </td>
                    <td>10 u</td>
                    <td>30%</td>
                    <td>$1,500.00</td>
                    <td class="fw-bold text-primary">$1,950.00</td>
                    <td><span class="badge badge-custom badge-custom-success">Activo</span></td>
                    <td class="text-end">
                        <button class="btn btn-light btn-sm text-primary rounded-pill px-3 me-2"><i class="bi bi-pencil"></i></button>
                        <button class="btn btn-light btn-sm text-danger rounded-pill px-3"><i class="bi bi-trash"></i></button>
                    </td>
                </tr>
                <tr>
                    <td>2</td>
                    <td class="fw-bold">Bolígrafo Azul Trazo Fino</td>
                    <td>Bic</td>
                    <td>Útiles escolares</td>
                    <td>
                        <span class="badge badge-custom badge-custom-danger">5 u</span>
                    </td>
                    <td>15 u</td>
                    <td>40%</td>
                    <td>$200.00</td>
                    <td class="fw-bold text-primary">$280.00</td>
                    <td><span class="badge badge-custom badge-custom-success">Activo</span></td>
                    <td class="text-end">
                        <button class="btn btn-light btn-sm text-primary rounded-pill px-3 me-2"><i class="bi bi-pencil"></i></button>
                        <button class="btn btn-light btn-sm text-danger rounded-pill px-3"><i class="bi bi-trash"></i></button>
                    </td>
                </tr>
                <tr>
                    <td>3</td>
                    <td class="fw-bold">Tablero de Dibujo Técnico A3</td>
                    <td>Pizzini</td>
                    <td>Útiles escolares</td>
                    <td>
                        <span class="badge badge-custom badge-custom-warning">8 u</span>
                    </td>
                    <td>8 u</td>
                    <td>35%</td>
                    <td>$12,000.00</td>
                    <td class="fw-bold text-primary">$16,200.00</td>
                    <td><span class="badge badge-custom badge-custom-success">Activo</span></td>
                    <td class="text-end">
                        <button class="btn btn-light btn-sm text-primary rounded-pill px-3 me-2"><i class="bi bi-pencil"></i></button>
                        <button class="btn btn-light btn-sm text-danger rounded-pill px-3"><i class="bi bi-trash"></i></button>
                    </td>
                </tr>
                <tr>
                    <td>4</td>
                    <td class="fw-bold">Calculadora Científica 240 Funciones</td>
                    <td>Casio</td>
                    <td>Tecnología básica</td>
                    <td>
                        <span class="badge badge-custom badge-custom-success">15 u</span>
                    </td>
                    <td>5 u</td>
                    <td>25%</td>
                    <td>$8,000.00</td>
                    <td class="fw-bold text-primary">$10,000.00</td>
                    <td><span class="badge badge-custom badge-custom-danger">Inactivo</span></td>
                    <td class="text-end">
                        <button class="btn btn-light btn-sm text-primary rounded-pill px-3 me-2"><i class="bi bi-pencil"></i></button>
                        <button class="btn btn-light btn-sm text-success rounded-pill px-3"><i class="bi bi-check-circle"></i></button>
                    </td>
                </tr>
            </tbody>
        </table>
    </div>
</div>

<!-- Modal Dialog -->
<div class="modal fade" id="productoModal" tabindex="-1" aria-labelledby="productoModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 rounded-4 shadow-lg">
            <div class="modal-header text-white rounded-top-4 py-3" style="background: linear-gradient(135deg, var(--primary) 0%, #6366f1 100%);">
                <h5 class="modal-title fw-bold" id="productoModalLabel"><i class="bi bi-box-seam me-2"></i>Nuevo Producto</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4">
                <form>
                    <div class="mb-3">
                        <label class="form-label text-muted small fw-bold">Nombre del Producto</label>
                        <input type="text" class="form-control form-control-custom" placeholder="Ej. Cuaderno Rivadavia A4" required />
                    </div>
                    <div class="row mb-3">
                        <div class="col-6">
                            <label class="form-label text-muted small fw-bold">Marca</label>
                            <select class="form-select form-control-custom">
                                <option value="1">Rivadavia</option>
                                <option value="2">Bic</option>
                                <option value="3">Pizzini</option>
                                <option value="4">Casio</option>
                            </select>
                        </div>
                        <div class="col-6">
                            <label class="form-label text-muted small fw-bold">Categoría</label>
                            <select class="form-select form-control-custom">
                                <option value="1">Útiles escolares</option>
                                <option value="2">Cuadernos</option>
                                <option value="3">Tecnología básica</option>
                            </select>
                        </div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-6">
                            <label class="form-label text-muted small fw-bold">Stock Mínimo</label>
                            <input type="number" class="form-control form-control-custom" placeholder="Ej. 10" required />
                        </div>
                        <div class="col-6">
                            <label class="form-label text-muted small fw-bold">Porcentaje Ganancia (%)</label>
                            <input type="number" step="0.01" class="form-control form-control-custom" placeholder="Ej. 30" required />
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label text-muted small fw-bold">Estado</label>
                        <div class="form-check form-switch mt-1">
                            <input class="form-check-input" type="checkbox" role="switch" id="prodActivo" checked>
                            <label class="form-check-label text-muted small" for="prodActivo">Producto Activo</label>
                        </div>
                    </div>
                    <div class="d-flex gap-2 justify-content-end mt-4">
                        <button type="button" class="btn btn-custom-secondary" data-bs-dismiss="modal">Cancelar</button>
                        <button type="button" class="btn btn-custom-primary" data-bs-dismiss="modal">Guardar</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

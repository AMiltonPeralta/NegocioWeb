@page
@model NegocioWeb.Pages.UsuariosModel
@{
    ViewData["Title"] = "Gestión de Usuarios";
}

<div class="row mb-4 align-items-center">
    <div class="col">
        <h2 class="fw-bold text-dark mb-1"><i class="bi bi-person-gear me-2 text-primary"></i>Usuarios</h2>
        <p class="text-muted mb-0">Administración de credenciales, perfiles y permisos del sistema.</p>
    </div>
    <div class="col-auto">
        <button type="button" class="btn btn-custom-primary" data-bs-toggle="modal" data-bs-target="#usuarioModal">
            <i class="bi bi-person-plus me-2"></i> Nuevo Usuario
        </button>
    </div>
</div>

<!-- Users Grid -->
<div class="card card-custom p-4">
    <div class="table-responsive">
        <table class="table table-custom align-middle">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Nombre</th>
                    <th>Email</th>
                    <th>Rol</th>
                    <th>Estado</th>
                    <th class="text-end">Acciones</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td>1</td>
                    <td class="fw-bold d-flex align-items-center gap-2">
                        <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center fw-bold" style="width: 32px; height: 32px; font-size: 0.85rem;">
                            MP
                        </div>
                        Milton Peralta
                    </td>
                    <td>milton.peralta@negocioweb.com</td>
                    <td>
                        <span class="badge bg-primary bg-opacity-10 text-primary fw-bold px-3 py-1.5 rounded-pill">Administrador</span>
                    </td>
                    <td><span class="badge badge-custom badge-custom-success">Activo</span></td>
                    <td class="text-end">
                        <button class="btn btn-light btn-sm text-primary rounded-pill px-3 me-2"><i class="bi bi-pencil"></i> Editar</button>
                        <button class="btn btn-light btn-sm text-danger rounded-pill px-3" disabled><i class="bi bi-trash"></i></button>
                    </td>
                </tr>
                <tr>
                    <td>2</td>
                    <td class="fw-bold d-flex align-items-center gap-2">
                        <div class="bg-info text-white rounded-circle d-flex align-items-center justify-content-center fw-bold" style="width: 32px; height: 32px; font-size: 0.85rem;">
                            JR
                        </div>
                        Juan Rodríguez
                    </td>
                    <td>juan.rodriguez@negocioweb.com</td>
                    <td>
                        <span class="badge bg-secondary bg-opacity-10 text-muted fw-bold px-3 py-1.5 rounded-pill">Vendedor</span>
                    </td>
                    <td><span class="badge badge-custom badge-custom-success">Activo</span></td>
                    <td class="text-end">
                        <button class="btn btn-light btn-sm text-primary rounded-pill px-3 me-2"><i class="bi bi-pencil"></i> Editar</button>
                        <button class="btn btn-light btn-sm text-danger rounded-pill px-3"><i class="bi bi-trash"></i> Desactivar</button>
                    </td>
                </tr>
                <tr>
                    <td>3</td>
                    <td class="fw-bold d-flex align-items-center gap-2">
                        <div class="bg-secondary text-white rounded-circle d-flex align-items-center justify-content-center fw-bold" style="width: 32px; height: 32px; font-size: 0.85rem;">
                            MG
                        </div>
                        María Gómez
                    </td>
                    <td>maria.gomez@negocioweb.com</td>
                    <td>
                        <span class="badge bg-secondary bg-opacity-10 text-muted fw-bold px-3 py-1.5 rounded-pill">Vendedor</span>
                    </td>
                    <td><span class="badge badge-custom badge-custom-danger">Inactivo</span></td>
                    <td class="text-end">
                        <button class="btn btn-light btn-sm text-primary rounded-pill px-3 me-2"><i class="bi bi-pencil"></i> Editar</button>
                        <button class="btn btn-light btn-sm text-success rounded-pill px-3"><i class="bi bi-check-circle"></i> Activar</button>
                    </td>
                </tr>
            </tbody>
        </table>
    </div>
</div>

<!-- Modal Dialog -->
<div class="modal fade" id="usuarioModal" tabindex="-1" aria-labelledby="usuarioModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 rounded-4 shadow-lg">
            <div class="modal-header text-white rounded-top-4 py-3" style="background: linear-gradient(135deg, var(--primary) 0%, #6366f1 100%);">
                <h5 class="modal-title fw-bold" id="usuarioModalLabel"><i class="bi bi-person-plus me-2"></i>Nuevo Usuario</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4">
                <form>
                    <div class="mb-3">
                        <label class="form-label text-muted small fw-bold">Nombre Completo</label>
                        <input type="text" class="form-control form-control-custom" placeholder="Ej. Milton Peralta" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label text-muted small fw-bold">Correo electrónico</label>
                        <input type="email" class="form-control form-control-custom" placeholder="Ej. milton@negocioweb.com" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label text-muted small fw-bold">Rol / Perfil</label>
                        <select class="form-select form-control-custom">
                            <option value="Vendedor">Vendedor</option>
                            <option value="Administrador">Administrador</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label text-muted small fw-bold">Contraseña Inicial</label>
                        <input type="password" class="form-control form-control-custom" placeholder="••••••••" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label text-muted small fw-bold">Estado</label>
                        <div class="form-check form-switch mt-1">
                            <input class="form-check-input" type="checkbox" role="switch" id="userActivo" checked>
                            <label class="form-check-label text-muted small" for="userActivo">Usuario Activo</label>
                        </div>
                    </div>
                    <div class="d-flex gap-2 justify-content-end mt-4">
                        <button type="button" class="btn btn-custom-secondary" data-bs-dismiss="modal">Cancelar</button>
                        <button type="button" class="btn btn-custom-primary" data-bs-dismiss="modal">Guardar</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

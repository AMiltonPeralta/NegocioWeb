@page
@model NegocioWeb.Pages.CategoriasModel
@{
    ViewData["Title"] = "Gestión de Categorías";
}

<div class="row mb-4 align-items-center">
    <div class="col">
        <h2 class="fw-bold text-dark mb-1"><i class="bi bi-tags me-2 text-primary"></i>Categorías</h2>
        <p class="text-muted mb-0">Administración de sectores y categorías de productos.</p>
    </div>
</div>

<div class="row g-4">
    <!-- Form (Add/Edit Category) -->
    <div class="col-lg-4">
        <div class="card card-custom p-4">
            <h5 class="fw-bold text-dark mb-3"><i class="bi bi-plus-circle text-primary me-2"></i>Nueva Categoría</h5>
            <form>
                <div class="mb-3">
                    <label class="form-label text-muted small fw-bold">Nombre de la Categoría</label>
                    <input type="text" class="form-control form-control-custom" placeholder="Ej. Útiles escolares" required />
                </div>
                <div class="mb-4">
                    <label class="form-label text-muted small fw-bold">Estado</label>
                    <div class="form-check form-switch mt-1">
                        <input class="form-check-input" type="checkbox" role="switch" id="catActivo" checked>
                        <label class="form-check-label text-muted small" for="catActivo">Categoría Activa</label>
                    </div>
                </div>
                <button type="submit" class="btn btn-custom-primary w-100"><i class="bi bi-save me-2"></i>Guardar Categoría</button>
            </form>
        </div>
    </div>

    <!-- Table of Categories -->
    <div class="col-lg-8">
        <div class="card card-custom p-4">
            <h5 class="fw-bold text-dark mb-3">Listado de Categorías</h5>
            <div class="table-responsive">
                <table class="table table-custom align-middle">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Nombre</th>
                            <th>Estado</th>
                            <th class="text-end">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var cat in Model.Categorias)
                        {
                            <tr>
                                <td>@cat.Id</td>
                                <td class="fw-bold">@cat.Nombre</td>
                                <td>
                                    @if (cat.Activo)
                                    {
                                        <span class="badge badge-custom badge-custom-success">Activo</span>
                                    }
                                    else
                                    {
                                        <span class="badge badge-custom badge-custom-danger">Inactivo</span>
                                    }
                                </td>
                                <td class="text-end">
                                    <button class="btn btn-light btn-sm text-primary rounded-pill px-3 me-2"><i class="bi bi-pencil"></i> Editar</button>
                                    @if (cat.Activo)
                                    {
                                        <button class="btn btn-light btn-sm text-danger rounded-pill px-3"><i class="bi bi-trash"></i> Desactivar</button>
                                    }
                                    else
                                    {
                                        <button class="btn btn-light btn-sm text-success rounded-pill px-3"><i class="bi bi-check-circle"></i> Activar</button>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
